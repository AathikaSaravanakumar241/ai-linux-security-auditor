# =============================================================================
# AI Linux Security Auditor — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- PostgreSQL ---
# Connection string for the PostgreSQL database.
# The docker-compose.yml in infrastructure/ creates this DB automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linux_audit

# --- Google Gemini API ---
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- SSH Defaults ---
# Timeout in seconds for SSH connection and per-command execution.
SSH_TIMEOUT=30
SSH_COMMAND_TIMEOUT=60

# --- Application ---
LOG_LEVEL=INFO

# Comma-separated CORS origins. Use * for development only.
# Examples:
#   - Local development (Vite + FastAPI separate): http://localhost:5173
#   - Docker-compose deployment: http://localhost:3000
#   - Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
